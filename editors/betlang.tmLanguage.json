{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "_comment": "SPDX-License-Identifier: PMPL-1.0-or-later",
  "name": "BetLang",
  "scopeName": "source.betlang",
  "fileTypes": [
    "bet"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#inference-methods"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#function-definitions"
    },
    {
      "include": "#type-definitions"
    },
    {
      "include": "#type-variables"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.betlang",
          "match": "--.*$"
        },
        {
          "name": "comment.block.betlang",
          "begin": "\\{-",
          "end": "-\\}",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.betlang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.betlang",
              "match": "\\\\[nrt\\\\\"0]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.betlang",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.float.scientific.betlang",
          "match": "\\b[0-9]+[eE][+-]?[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.betlang",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.betlang",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.unknown.betlang",
          "match": "\\b(unknown)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.betlang",
          "match": "\\b(if|then|else|end|match|do|return|in)\\b"
        },
        {
          "name": "keyword.declaration.betlang",
          "match": "\\b(bet|let|fun|type|module|import|export|rec)\\b"
        },
        {
          "name": "keyword.operator.word.betlang",
          "match": "\\b(and|or|not|xor)\\b"
        },
        {
          "name": "keyword.other.probabilistic.betlang",
          "match": "\\b(sample|observe|infer|parallel|weighted)\\b"
        }
      ]
    },
    "inference-methods": {
      "patterns": [
        {
          "name": "support.constant.inference.betlang",
          "match": "\\b(MCMC|HMC|SMC|VI)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.betlang",
          "match": "->|=>|<-"
        },
        {
          "name": "keyword.operator.comparison.betlang",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.betlang",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.pipe.betlang",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.concat.betlang",
          "match": "\\+\\+"
        },
        {
          "name": "keyword.operator.compose.betlang",
          "match": ">>"
        },
        {
          "name": "keyword.operator.cons.betlang",
          "match": "::"
        },
        {
          "name": "keyword.operator.arithmetic.betlang",
          "match": "\\+|-|\\*|/|%|\\^"
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "match": "\\b(fun)\\s+([a-z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.betlang"
            },
            "2": {
              "name": "entity.name.function.betlang"
            }
          }
        },
        {
          "match": "\\b(let)\\s+([a-z_][a-zA-Z0-9_]*)\\s*=",
          "captures": {
            "1": {
              "name": "keyword.declaration.betlang"
            },
            "2": {
              "name": "entity.name.function.betlang"
            }
          }
        }
      ]
    },
    "type-definitions": {
      "patterns": [
        {
          "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.betlang"
            },
            "2": {
              "name": "entity.name.type.betlang"
            }
          }
        }
      ]
    },
    "type-variables": {
      "patterns": [
        {
          "name": "variable.other.type-variable.betlang",
          "match": "'[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.type.betlang",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "variable.other.betlang",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  },
  "_taxonomy": "editors/textmate-grammar"
}
